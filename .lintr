linters: linters_with_defaults(
    # air (air.toml) owns code layout: line length, indentation, and spacing.
    # Disable the lintr linters that duplicate it, to avoid conflicting or
    # unfixable reports (e.g. a long unbreakable string air leaves as-is).
    line_length_linter = NULL,
    indentation_linter = NULL,
    object_usage_linter = NULL,
    # This package documents statistical provenance and formulae in comments
    # (e.g. `psych::ICC()`, ANOVA identities); code-like comments are intentional.
    commented_code_linter = NULL
  )
encoding: "UTF-8"
exclusions: list(
    "tests/testthat.R",
    "tests/spelling.R",
    # Committed statistical-review verification scripts (PRINCIPLES.md #19) use
    # mathematical single-capital matrix notation (C, V, L) and constants that do
    # not follow package snake_case; they are provenance artifacts, not package code.
    "data-raw/reviews"
  )
